# Flask
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=change-me-to-a-random-secret-key

# Database
DATABASE=tpims.db

# Groq AI (free cloud — no GPU needed, 30 req/min free)
# Get free key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Email (Brevo/Sendinblue)
LOW_STOCK_EMAIL_ENABLED=0
EMAIL_PROVIDER=brevo
EMAIL_BREVO_KEY=your-brevo-api-key
EMAIL_FROM=noreply@yourcompany.com
EMAIL_TO=you@yourcompany.com

# Optional: Gmail SMTP
# EMAIL_GMAIL_FROM=your@gmail.com
# EMAIL_SMTP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Custom SMTP
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_USE_TLS=1
# EMAIL_SMTP_USERNAME=user
# EMAIL_SMTP_PASSWORD=pass
